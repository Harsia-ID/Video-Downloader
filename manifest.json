{
  "manifest_version": 3,
  "name": "Smart Media Downloader Pro",
  "version": "5.0",
  "description": "Real-time media detector & downloader with Auto-Bypass feature. (by harsiadev)",
  "author": "harsiadev",
  "permissions": [
    "activeTab",
    "downloads",
    "webRequest",
    "storage",
    "clipboardWrite"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Smart Media Downloader"
  },
  "icons": {
    "48": "icon.png"
  }
}
